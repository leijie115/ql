#!name=麓豆Token自动更新
#!desc=自动抓取麓豆小程序token并更新到青龙面板环境变量
#!author=leos
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Cookie.png
#!arguments=qlurl:请填写青龙地址,qlclientid:请填写ClientID,qlclientsecret:请填写ClientSecret,tgbottoken:可选,tgchatid:可选
#!arguments-desc=qlurl: 青龙面板地址(如 https://ql.example.com)\nqlclientid: 青龙应用Client ID\nqlclientsecret: 青龙应用Client Secret\ntgbottoken: Telegram Bot Token(可选)\ntgchatid: Telegram Chat ID(可选)

[Script]
麓豆Token = type=http-response,pattern=^https://luhu-beta1-web\.crm\.luxelakes\.com//?v1/user/userInfo,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/leijie115/ql/main/surge/ludou/ludou_token.js,argument={{{qlurl}}},{{{qlclientid}}},{{{qlclientsecret}}},{{{tgbottoken}}},{{{tgchatid}}}

[MITM]
hostname = %APPEND% luhu-beta1-web.crm.luxelakes.com
